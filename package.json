{
  "name": "zotero-traffic-literature-push",
  "type": "module",
  "version": "1.0.0",
  "description": "基于 Zotero 的交通文献推送",
  "config": {
    "addonName": "基于 Zotero 的交通文献推送",
    "addonID": "literature-tracker@example.com",
    "addonRef": "literature-tracker",
    "addonInstance": "LiteratureTracker",
    "prefsPrefix": "extensions.zotero.literature-tracker"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yinyanhui0123/-zetero-.git"
  },
  "author": "yinyanhui0123",
  "bugs": {
    "url": "https://github.com/yinyanhui0123/-zetero-/issues"
  },
  "homepage": "https://github.com/yinyanhui0123/-zetero-#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "npx zotero-plugin serve",
    "build": "npx zotero-plugin build && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "npx zotero-plugin release",
    "test": "npx zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "natural": "^6.1.0",
    "sqlite3": "^5.1.6",
    "turndown": "^7.1.3",
    "zotero-plugin-toolkit": "^5.1.0-beta.13"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.7",
    "chai": "^6.2.1",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.2",
    "zotero-types": "^4.1.0-beta.4"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
