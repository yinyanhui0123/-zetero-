{
  "compilerOptions": {
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": false
  },
  "include": [
    "src",
    "typings"
  ],
  "exclude": [
    "build",
    "addon",
    "node_modules"
  ]
}